<Window x:Class="RoadTraffic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoadTraffic Engine v0.2"
        Width="680" Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="White">

    <Grid Margin="14,10,14,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>        <!-- levy panel -->
            <ColumnDefinition Width="1"/>        <!-- separator -->
            <ColumnDefinition Width="295"/>      <!-- pravy panel -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!--  LEVY PANEL — status + density slider   -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Radek 0: Stav pripojeni -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#FF4444"
                         Margin="0,2,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Disconnected"
                           Foreground="#AAAAAA" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Radek 1: Vozidla -->
            <TextBlock Grid.Row="1" x:Name="VehiclesText" Text="Vehicles: —/30"
                       Foreground="#DDDDDD" Margin="18,0,0,2"/>

            <!-- Radek 2: Silnice -->
            <TextBlock Grid.Row="2" x:Name="RoadsText" Text="Roads: — segments"
                       Foreground="#888899" Margin="18,0,0,2"/>

            <!-- Radek 3: Km -->
            <TextBlock Grid.Row="3" x:Name="KmText" Text=""
                       Foreground="#888899" Margin="18,0,0,0" VerticalAlignment="Top"/>

            <!-- Radek 4: Density slider -->
            <StackPanel Grid.Row="4" VerticalAlignment="Bottom">

                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Traffic Density" Foreground="#CCCCDD"
                               FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBox x:Name="DensityTextBox" Width="38" Height="22"
                                 Background="#2D2D44" Foreground="White"
                                 BorderBrush="#555577" CaretBrush="White"
                                 TextAlignment="Center" VerticalContentAlignment="Center"
                                 FontSize="12" Text="50"/>
                        <TextBlock Text="%" Foreground="#AAAACC"
                                   VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>

                <Slider x:Name="DensitySlider" Minimum="0" Maximum="100" Value="50"
                        Margin="0,0,0,2"/>

                <Grid>
                    <TextBlock Text="Local ←" Foreground="#445566" FontSize="10"/>
                    <TextBlock Text="→ Highway" Foreground="#445566" FontSize="10"
                               HorizontalAlignment="Right"/>
                </Grid>

            </StackPanel>
            <!-- Radek 5: Traffic Cars slider -->
            <StackPanel Grid.Row="5" Margin="0,6,0,0">

                <Rectangle Height="1" Fill="#333355" Margin="0,0,0,6"/>

                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Traffic Cars" Foreground="#CCCCDD"
                               FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBlock x:Name="TrafficCarsValueText"
                                   Text="150" Foreground="#AAAACC"
                                   FontSize="12" VerticalAlignment="Center" MinWidth="28"
                                   TextAlignment="Right"/>
                        <TextBlock Text=" cars" Foreground="#AAAACC"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Slider x:Name="TrafficCarsSlider"
                        Minimum="0" Maximum="800" Value="150"
                        TickFrequency="50" IsSnapToTickEnabled="False"
                        Margin="0,0,0,2"/>

                <Grid>
                    <TextBlock Text="0 ←" Foreground="#445566" FontSize="10"/>
                    <TextBlock Text="→ 800" Foreground="#445566" FontSize="10"
                               HorizontalAlignment="Right"/>
                </Grid>

                <TextBlock x:Name="FlareCountText"
                           Text="Rendered flares: 0"
                           Foreground="#AAAACC" FontSize="11" FontWeight="SemiBold"
                           Margin="0,4,0,0"/>

            </StackPanel>

        </Grid>

        <!-- Vertikalni separator -->
        <Rectangle Grid.Column="1" Fill="#333355"/>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  PRAVY PANEL — MaxVehicles + road types + Hz   -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="2" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Radek 0: Max Vehicles label + textbox -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="Max Vehicles" Foreground="#CCCCDD"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBox x:Name="MaxVehiclesTextBox" Width="40" Height="22"
                         HorizontalAlignment="Right"
                         Background="#2D2D44" Foreground="White"
                         BorderBrush="#555577" CaretBrush="White"
                         TextAlignment="Center" VerticalContentAlignment="Center"
                         FontSize="12" Text="30"/>
            </Grid>

            <!-- Radek 1: MaxVehicles slider -->
            <Slider x:Name="MaxVehiclesSlider" Grid.Row="1"
                    Minimum="0" Maximum="400" Value="30"
                    IsSnapToTickEnabled="True" TickFrequency="10"
                    Margin="0,0,0,6"/>

            <!-- Radek 2: Statistiky spawn/despawn -->
            <StackPanel Grid.Row="2" Margin="0,0,0,4">
                <TextBlock x:Name="SpawnRangeText"
                           Text="Spawn:    50 m – 5 000 m  |  highway 15 km"
                           Foreground="#888899" FontSize="10"/>
                <TextBlock x:Name="DespawnRangeText"
                           Text="Despawn: 15 000 m  |  LOD.Light 5–15 km"
                           Foreground="#888899" FontSize="10"/>
            </StackPanel>

            <!-- Radek 3: Road type checkboxy -->
            <StackPanel Grid.Row="3" VerticalAlignment="Top" Margin="0,4,0,0">
                <TextBlock Text="Road Types" Foreground="#CCCCDD"
                           FontSize="12" Margin="0,0,0,5"/>
                <UniformGrid Columns="2" Rows="4">
                    <CheckBox x:Name="ChkMotorway"    Content="Motorway"    Tag="Motorway"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                    <CheckBox x:Name="ChkTrunk"       Content="Trunk"       Tag="Trunk"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                    <CheckBox x:Name="ChkPrimary"     Content="Primary"     Tag="Primary"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                    <CheckBox x:Name="ChkSecondary"   Content="Secondary"   Tag="Secondary"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                    <CheckBox x:Name="ChkTertiary"    Content="Tertiary"    Tag="Tertiary"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                    <CheckBox x:Name="ChkResidential" Content="Residential" Tag="Residential"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                    <CheckBox x:Name="ChkUnclassified" Content="Unclassified" Tag="Unclassified"
                              Foreground="#DDDDDD" FontSize="11" IsChecked="True" Margin="0,2"/>
                </UniformGrid>
            </StackPanel>

            <!-- Radek 4: Update Rate dropdown -->
            <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
                <TextBlock Text="Update Rate" Foreground="#CCCCDD"
                           FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="TickrateComboBox"
                          SelectedIndex="0"
                          Background="#2D2D44" Foreground="White"
                          BorderBrush="#555577">
                    <ComboBoxItem Content="60 Hz  (smooth)"      Tag="16"/>
                    <ComboBoxItem Content="30 Hz  (balanced)"    Tag="33"/>
                    <ComboBoxItem Content="20 Hz  (performance)" Tag="50"/>
                </ComboBox>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
